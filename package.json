{
  "name": "vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e:setup": "playwright test --project=setup --headed",
    "e2e:setup:limited": "cross-env AUTH_USER=limited playwright test --project=setup --headed",
    "e2e:smoke": "playwright test --project=smoke-admin --project=smoke-limited",
    "e2e:smoke:headed": "playwright test --project=smoke-admin --project=smoke-limited --headed",
    "e2e:stress": "playwright test --project=stress-admin --project=stress-limited",
    "e2e:stress:headed": "playwright test --project=stress-admin --project=stress-limited --headed",
    "e2e:rbac": "playwright test --project=rbac-admin --project=rbac-limited",
    "e2e:rbac:headed": "playwright test --project=rbac-admin --project=rbac-limited --headed",
    "e2e:all": "playwright test --project=smoke-admin --project=smoke-limited --project=stress-admin --project=stress-limited --project=rbac-admin --project=rbac-limited",
    "e2e:all:headed": "playwright test --project=smoke-admin --project=smoke-limited --project=stress-admin --project=stress-limited --project=rbac-admin --project=rbac-limited --headed",
    "e2e:failed": "playwright test --last-failed",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "solution:pack": "node scripts/pack-solution.mjs",
    "solution:pack:managed": "node scripts/pack-solution.mjs --managed",
    "solution:pull": "node scripts/pull-solution.mjs",
    "ci:encode-auth": "node scripts/encode-auth-for-ci.mjs"
  },
  "dependencies": {
    "@microsoft/power-apps": "^1.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@microsoft/power-apps-vite": "^1.0.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^3.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.1"
  }
}
