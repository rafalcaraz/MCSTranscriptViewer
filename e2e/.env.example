# Copy this file to e2e/.env and fill in your values.
# Real shell env vars override anything in here.

# Dataverse environment URL used by the Browse via Flows tests.
# Required for stress.spec.ts (flow tests) and rbac.spec.ts.
TEST_ENV_URL=https://yourorg.crm.dynamics.com

# Which saved auth state to replay (e2e/.auth/<AUTH_USER>.json).
# Defaults to "admin".
# AUTH_USER=admin
